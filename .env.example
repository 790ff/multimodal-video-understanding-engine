# Application metadata
APP_NAME="Multimodal Video Understanding Engine"
APP_VERSION="0.1.0"
ENVIRONMENT="development"

# Provider selection
# Supported values: openai, gemini
MODEL_PROVIDER="openai"

# Optional comma-separated fallback order for transcription, for example: gemini,openai
TRANSCRIPTION_PROVIDER_ORDER=""

# Optional override for frame summaries. Leave empty to use MODEL_PROVIDER.
FRAME_ANALYSIS_PROVIDER=""

# Provider credentials
# Required only for the provider selected for real analysis. Do not commit real keys.
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Provider models
TRANSCRIPTION_MODEL="whisper-1"
VISION_MODEL="gpt-4.1-mini"
GEMINI_MODEL="gemini-3.5-flash"

# Local storage
DATABASE_URL="sqlite:///data/video_ai.sqlite3"
UPLOAD_DIR="data/uploads"
AUDIO_DIR="data/audio"
FRAME_DIR="data/frames"

# Processing limits
FRAME_SAMPLE_SECONDS=2
FFMPEG_TIMEOUT_SECONDS=120
MAX_UPLOAD_MB=250
ALLOWED_VIDEO_EXTENSIONS="mp4,mov"

# Local web app origins allowed to call the API
CORS_ALLOWED_ORIGINS="http://127.0.0.1:5173,http://localhost:5173"
